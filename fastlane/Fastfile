require 'yaml'

default_platform(:ios)

# --- ロケール関連設定（App Store に合わせた正規化） ---
# App Store Connectで設定されているローカライゼーション: 日本語と英語（アメリカ）
# 日本語は "ja" または "ja-JP" の可能性があるため、両方を含める
ALLOWED_LOCALES = ["en-US", "ja", "ja-JP"]

def normalize_localized_hash(h)
  return h unless h.is_a?(Hash)
  # すべてのロケールを保持（フィルタリングしない）
  # App Store Connect APIが自動的に正しいロケールを選択する
  h
end

# APIキーがあれば使い、無ければ nil（Apple ID フォールバック用）
def asc_api_key_or_nil
  key_id = ENV['ASC_KEY_ID'].to_s
  issuer = ENV['ASC_ISSUER_ID'].to_s

  UI.message("🔍 Debug: ASC_KEY_ID = '#{key_id}'")
  UI.message("🔍 Debug: ASC_ISSUER_ID = '#{issuer}'")

  return nil if key_id.empty? || issuer.empty?

  key_path = (ENV['ASC_P8_PATH'] || File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")).to_s
  UI.message("🔍 Debug: key_path = '#{key_path}'")
  UI.message("🔍 Debug: File.exist?(key_path) = #{File.exist?(key_path)}")

  return nil unless File.exist?(key_path)

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer,
    key_filepath: key_path,
    duration: 1200,
    in_house: false
  )
end

# helper: Pod install を行う（bundle exec が失敗しても pod を試す）
def safe_pod_install
  # GEM_PATH をクリアしてシステムの gem パスを使用しないようにする
  sh("cd ../ios && export LANG=en_US.UTF-8 && unset GEM_PATH && if [ -f Gemfile ]; then bundle config set --local path 'vendor/bundle' && bundle install && bundle exec pod install --repo-update || pod install --repo-update; else pod install --repo-update; fi && cd ..")
end

# helper: pubspec.yaml からバージョン情報を取得
def get_version_info
  pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
  unless File.exist?(pubspec_path)
    UI.user_error!("❌ pubspec.yaml not found at #{pubspec_path}")
  end
  pubspec = YAML.load_file(pubspec_path)
  pub_version = pubspec["version"]       # 例: "2.2.5+31"
  version_number, build_number = pub_version.split("+")
  {
    version: version_number,
    build: build_number,
    full: pub_version
  }
end

# helper: ビルド済みファイルの存在チェック
def check_built_files(version_info)
  aab_path = File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__)
  ipa_path = File.expand_path("../Runner.ipa", __dir__)
  
  {
    aab_exists: File.exist?(aab_path),
    ipa_exists: File.exist?(ipa_path),
    aab_path: aab_path,
    ipa_path: ipa_path
  }
end

# helper: Android changelog を生成（日本語と英語の両方）
def generate_android_changelogs(build_number, release_note, release_note_en)
  changelog_ja_path = File.expand_path("./metadata/android/ja-JP/changelogs/#{build_number}.txt", __dir__)
  changelog_en_path = File.expand_path("./metadata/android/en-US/changelogs/#{build_number}.txt", __dir__)
  
  sh("mkdir -p #{File.dirname(changelog_ja_path)}")
  sh("mkdir -p #{File.dirname(changelog_en_path)}")
  
  File.write(changelog_ja_path, release_note)
  File.write(changelog_en_path, release_note_en)
  
  UI.message("✅ Android changelogs generated:")
  UI.message("   - #{changelog_ja_path}: #{release_note}")
  UI.message("   - #{changelog_en_path}: #{release_note_en}")
end

# 固定の whatsNew（ここを変えたいなら書き換えてください）
FIXED_WHATSNEW_EN = "Bug fixes and improvements."
FIXED_WHATSNEW_JA = "バグ修正と改善を行いました。"

# 固定の promotional text（必要なら編集）
FIXED_PROMOTIONAL_EN = "Learn calculus and physics efficiently with random questions!"
FIXED_PROMOTIONAL_JA = "ランダム出題で微分積分と物理を効率的に学ぼう！"

# 統合リリースレーン（iOS + Android）
desc "iOS と Android の両方を一撃でリリース"
desc "オプション: skip_build:true (既存ビルドを使用), skip_ios:true (iOSをスキップ), skip_android:true (Androidをスキップ)"
lane :release_all_platforms do |options|
  # オプション or デフォルトのリリースノート（ただし deliver 側は固定に上書き）
  release_note = options[:notes] || "バグ修正と改善を行いました"
  release_note_en = options[:notes_en] || "Bug fixes and improvements"
  skip_build = options[:skip_build] || false
  skip_ios = options[:skip_ios] || false
  skip_android = options[:skip_android] || false
  
  UI.header("🚀 Starting release process")
  UI.message("📝 Release notes (ja): #{release_note.inspect}")
  UI.message("📝 Release notes (en): #{release_note_en.inspect}")
  UI.message("⚙️  Options: skip_build=#{skip_build}, skip_ios=#{skip_ios}, skip_android=#{skip_android}")

  # --- pubspec.yaml からバージョン取得 ---
  version_info = get_version_info
  version_number = version_info[:version]
  build_number = version_info[:build]

  UI.message("📦 Version: #{version_number} (#{build_number})")
  
  # ビルド済みファイルのチェック
  built_files = check_built_files(version_info)
  if built_files[:aab_exists]
    UI.message("✅ Found existing AAB: #{built_files[:aab_path]}")
  end
  if built_files[:ipa_exists]
    UI.message("✅ Found existing IPA: #{built_files[:ipa_path]}")
  end

  #####################
  # iOS release_notes.txt に書き込み（メタデータファイルの情報を優先して使用）
  #####################
  # コマンドラインで指定されたリリースノートをメタデータファイルに書き込む
  # 他のメタデータファイル（full_description.txt、short_description.txt、title.txt、name.txtなど）は
  # 既存のファイルがそのまま使用される（skip_metadata: false のため）
  # 注意: Fastlaneは "ja" ディレクトリを期待する（"ja-JP" はサポートされていない）
  release_notes_ja_path = "./metadata/ja/release_notes.txt"
  release_notes_en_path = "./metadata/en-US/release_notes.txt"
  
  sh("mkdir -p #{File.dirname(release_notes_ja_path)}")
  sh("mkdir -p #{File.dirname(release_notes_en_path)}")
  
  File.write(release_notes_ja_path, release_note)
  File.write(release_notes_en_path, release_note_en)
  
  UI.message("✅ iOS release_notes written to metadata files")
  UI.message("   - #{release_notes_ja_path}: #{release_note}")
  UI.message("   - #{release_notes_en_path}: #{release_note_en}")
  UI.message("📋 All metadata files (full_description.txt, short_description.txt, title.txt, name.txt, etc.) will be used from fastlane/metadata/")

  #####################
  # Flutter 共通ビルド
  #####################
  unless skip_build
    UI.header("🔨 Building Flutter app")
    sh("cd .. && flutter clean")
    sh("cd .. && flutter pub get")
    safe_pod_install

    # Android AAB
    unless skip_android
      UI.message("📱 Building Android AAB...")
      sh("cd .. && flutter build appbundle --release --build-name #{version_number} --build-number #{build_number}")
    end

    #####################
    # iOS ビルド
    #####################
    unless skip_ios
      UI.message("🍎 Building iOS app...")
      increment_version_number(
        version_number: version_number,
        xcodeproj: File.expand_path("../ios/Runner.xcodeproj", __dir__)
      )
      increment_build_number(
        build_number: build_number,
        xcodeproj: File.expand_path("../ios/Runner.xcodeproj", __dir__)
      )
      build_app(
        workspace: File.expand_path("../ios/Runner.xcworkspace", __dir__),
        scheme: "Runner",
        export_method: "app-store",
        output_directory: File.expand_path("..", __dir__),
        clean: false,
        suppress_xcode_output: false
      )
    end
  else
    UI.message("⏭️  Skipping build (using existing files)")
    # ビルド済みファイルの存在確認
    unless skip_android
      unless built_files[:aab_exists]
        UI.user_error!("❌ AAB file not found at #{built_files[:aab_path]}. Remove skip_build option or build first.")
      end
    end
    unless skip_ios
      unless built_files[:ipa_exists]
        UI.user_error!("❌ IPA file not found at #{built_files[:ipa_path]}. Remove skip_build option or build first.")
      end
    end
  end

  #####################
  # iOS アップロード
  #####################
  unless skip_ios
    UI.header("🍎 Uploading iOS app to App Store Connect")
    
    # Info.plistから暗号化設定を取得
    uses_non_exempt = get_info_plist_value(
      path: File.expand_path("../ios/Runner/Info.plist", __dir__),
      key: "ITSAppUsesNonExemptEncryption"
    ) || false

    UI.message("🔍 ITSAppUsesNonExemptEncryption = #{uses_non_exempt}")

    # iOS アップロード（APIキー優先／無ければ Apple ID フォールバック）
    api = asc_api_key_or_nil
  if api
    UI.message("🔑 Using App Store Connect API Key")
    deliver_common = {
      api_key: api,
      force: true,
      # メタデータファイル（fastlane/metadata/*/）から全ての情報を読み込む
      # - release_notes.txt: コマンドラインで指定された内容が書き込まれている
      # - full_description.txt, short_description.txt, title.txt, name.txt: 既存のファイルが使用される
      skip_metadata: false,
      skip_screenshots: true,
      skip_app_version_update: false,
      # ユーザーが App Store Connect 上で「審査へ提出」ボタンを押す前提なので、ここでは提出しない
      submit_for_review: false,
      automatic_release: false, # 審査通過後の自動リリースはしない（手動でリリース）
      ignore_language_directory_validation: true, # ja-JPディレクトリの検証をスキップ
      promotional_text: {
        "en-US" => FIXED_PROMOTIONAL_EN,
        "ja" => FIXED_PROMOTIONAL_JA
      },
      submission_information: {
        add_id_info_limits_tracking: true,
        add_id_info_serves_ads: false,
        add_id_info_tracks_action: true,
        add_id_info_tracks_install: true,
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: false,
        export_compliance_platform: "ios",
        export_compliance_compliance_required: false,
        export_compliance_encryption_updated: false,
        export_compliance_app_type: nil,
        export_compliance_uses_encryption: uses_non_exempt,
        export_compliance_uses_non_exempt_encryption: uses_non_exempt,
        export_compliance_is_exempt: !uses_non_exempt
      },
      run_precheck_before_submit: false
    }

    # deliver_common のロケールを正規化（念のため）
    if deliver_common[:promotional_text].is_a?(Hash)
      deliver_common[:promotional_text] = normalize_localized_hash(deliver_common[:promotional_text])
    end

    UI.message("📋 All metadata files will be read from fastlane/metadata/")
    UI.message("   - release_notes.txt: #{release_note} (ja), #{release_note_en} (en-US)")
    UI.message("   - Other metadata files (full_description.txt, short_description.txt, title.txt, name.txt, etc.) will be used as-is")
    UI.message("🔍 deliver_common.promotional_text = #{deliver_common[:promotional_text].inspect}")

    # deliver 実行
    begin
      deliver(deliver_common)
      UI.success("✅ iOS app successfully submitted for review!")
    rescue => e
      UI.error("❌ Failed to submit iOS app for review")
      UI.error("   Error: #{e.message}")
      UI.error("   Class: #{e.class}")
      if e.backtrace
        UI.error("   Backtrace:")
        e.backtrace.first(5).each { |line| UI.error("     #{line}") }
      end
      UI.message("⚠️  Continuing with Android release despite iOS error...")
      # raise を削除して続行
    end
  else
    UI.message("⚠️  App Store Connect API Key not found, using Apple ID fallback")
    UI.message("💡 Set ASC_KEY_ID, ASC_ISSUER_ID, ASC_P8_PATH environment variables to use API Key")

    # Apple ID フォールバック：app-specific password が必要
    # FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD を環境変数にセットしてください。
    deliver_common = {
      username: ENV['FASTLANE_USER'] || "syunsukerunrun0306@yahoo.co.jp",
      # ユーザーが App Store Connect 上で「審査へ提出」ボタンを押す前提なので、ここでは提出しない
      submit_for_review: false,
      force: true,
      automatic_release: false, # 審査通過後の自動リリースはしない（手動でリリース）
      # メタデータファイル（fastlane/metadata/*/）から全ての情報を読み込む
      # - release_notes.txt: コマンドラインで指定された内容が書き込まれている
      # - full_description.txt, short_description.txt, title.txt, name.txt: 既存のファイルが使用される
      skip_metadata: false,
      skip_screenshots: true,
      ignore_language_directory_validation: true, # ja-JPディレクトリの検証をスキップ
      promotional_text: {
        "en-US" => FIXED_PROMOTIONAL_EN,
        "ja" => FIXED_PROMOTIONAL_JA
      },
      submission_information: {
        export_compliance_uses_encryption: uses_non_exempt,
        export_compliance_uses_non_exempt_encryption: uses_non_exempt,
        export_compliance_is_exempt: !uses_non_exempt,
        export_compliance_encryption_updated: false,
        add_id_info_uses_idfa: false
      }
    }

    # deliver_common のロケールを正規化（念のため）
    if deliver_common[:promotional_text].is_a?(Hash)
      deliver_common[:promotional_text] = normalize_localized_hash(deliver_common[:promotional_text])
    end

    UI.message("📋 All metadata files will be read from fastlane/metadata/")
    UI.message("   - release_notes.txt: #{release_note} (ja), #{release_note_en} (en-US)")
    UI.message("   - Other metadata files (full_description.txt, short_description.txt, title.txt, name.txt, etc.) will be used as-is")
    UI.message("🔍 deliver_common.promotional_text = #{deliver_common[:promotional_text].inspect}")

    # deliver 実行
    begin
      deliver(deliver_common)
      UI.success("✅ iOS app successfully submitted for review!")
    rescue => e
      UI.error("❌ Failed to submit iOS app for review")
      UI.error("   Error: #{e.message}")
      UI.error("   Class: #{e.class}")
      if e.backtrace
        UI.error("   Backtrace:")
        e.backtrace.first(5).each { |line| UI.error("     #{line}") }
      end
      UI.message("⚠️  Continuing with Android release despite iOS error...")
      # raise を削除して続行
    end
  end
  else
    UI.message("⏭️  Skipping iOS upload")
  end

  #####################
  # Android changelog 自動生成
  #####################
  unless skip_android
    UI.header("🤖 Uploading Android app to Google Play")
    generate_android_changelogs(build_number, release_note, release_note_en)

    #####################
    # Android アップロード
    #####################
    begin
      upload_to_play_store(
        package_name: "com.joymath",
        json_key: File.expand_path("./joy-math-fastlane.json", __dir__),
        track: "production",
        # ユーザーが Play Console 上で「審査へ送信」操作をする前提なので、ここでは review 送信しない
        changes_not_sent_for_review: true,
        aab: File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__),
        metadata_path: File.expand_path("./metadata/android", __dir__)
      )
      UI.success("✅ Android app successfully uploaded!")
    rescue => e
      UI.error("❌ Failed to upload Android app")
      UI.error("   Error: #{e.message}")
      UI.error("   Class: #{e.class}")
      if e.backtrace
        UI.error("   Backtrace:")
        e.backtrace.first(5).each { |line| UI.error("     #{line}") }
      end
      raise unless skip_ios  # iOSもスキップしている場合はエラーを投げる
    end
  else
    UI.message("⏭️  Skipping Android upload")
  end

  UI.success("🎉 Release process completed!")
  if skip_ios || skip_android
    UI.message("📋 Note: Some platforms were skipped. Check the logs above for details.")
  end
end

platform :ios do
  desc "Flutter Android と iOS のリリースを自動化"
  lane :release_all do |options|
    release_note = options[:notes] || "バグ修正と改善を行いました"
    release_note_en = options[:notes_en] || "Bug fixes and improvements"
    UI.message("release_note: #{release_note.inspect}")

    # --- pubspec.yaml からバージョン取得 ---
    pubspec = YAML.load_file("../pubspec.yaml")
    pub_version = pubspec["version"]       # 例: "2.2.5+31"
    version_number, build_number = pub_version.split("+")

    uses_non_exempt = get_info_plist_value(
      path: File.expand_path("../ios/Runner/Info.plist", __dir__),
      key: "ITSAppUsesNonExemptEncryption"
    )

    UI.message("versionName: #{version_number}, versionCode: #{build_number}")

    #####################
    # Flutter 共通ビルド
    #####################
    sh("cd .. && flutter clean")
    sh("cd .. && flutter pub get")
    safe_pod_install

    # Android AAB
    sh("cd .. && flutter build appbundle --release --build-name #{version_number} --build-number #{build_number}")

    #####################
    # iOS ビルド
    #####################
    increment_version_number(
      version_number: version_number,
      xcodeproj: File.expand_path("../ios/Runner.xcodeproj", __dir__)
    )

    increment_build_number(
      build_number: build_number,
      xcodeproj: File.expand_path("../ios/Runner.xcodeproj", __dir__)
    )

    build_app(
      workspace: File.expand_path("../ios/Runner.xcworkspace", __dir__),
      scheme: "Runner",
      export_method: "app-store",
      xcodebuild_formatter: nil
    )

    # deliver：Apple ID フォールバックを含め、必要なロケールの whatsNew を必ず渡す
    deliver_common = {
      username: ENV['FASTLANE_USER'] || "syunsukerunrun0306@yahoo.co.jp",
      # ユーザーが App Store Connect 上で「審査へ提出」ボタンを押す前提なので、ここでは提出しない
      submit_for_review: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true,
      # 固定で必ず whatsNew を入れる
      # App Store Connectで設定されているローカライゼーションに合わせて、ja と ja-JP の両方を含める
      release_notes: {
        "en-US" => FIXED_WHATSNEW_EN,
        "ja" => FIXED_WHATSNEW_JA,
        "ja-JP" => FIXED_WHATSNEW_JA
      },
      promotional_text: {
        "en-US" => FIXED_PROMOTIONAL_EN,
        "ja" => FIXED_PROMOTIONAL_JA
      },
      submission_information: {
        export_compliance_uses_encryption: uses_non_exempt || false,
        export_compliance_uses_non_exempt_encryption: uses_non_exempt || false,
        export_compliance_is_exempt: !uses_non_exempt,
        export_compliance_encryption_updated: false,
        add_id_info_uses_idfa: false
      }
    }

    # deliver_common のロケールを正規化（念のため）
    if deliver_common[:release_notes].is_a?(Hash)
      deliver_common[:release_notes] = normalize_localized_hash(deliver_common[:release_notes])
    end
    if deliver_common[:promotional_text].is_a?(Hash)
      deliver_common[:promotional_text] = normalize_localized_hash(deliver_common[:promotional_text])
    end

    UI.message("🔍 deliver_common.release_notes = #{deliver_common[:release_notes].inspect}")
    UI.message("🔍 deliver_common.promotional_text = #{deliver_common[:promotional_text].inspect}")

    deliver(deliver_common)

    #####################
    # Android changelog 自動生成
    #####################
    changelog_path = "./metadata/android/ja-JP/changelogs/#{build_number}.txt"
    sh("mkdir -p #{File.dirname(changelog_path)}")
    File.write(changelog_path, release_note)
    UI.message("Android changelog generated at #{changelog_path}")

    #####################
    # Android ビルド
    #####################
    gradle(
      task: "assembleRelease",
      project_dir: "../android",
      properties: {
        "versionName" => version_number,
        "versionCode" => build_number
      }
    )

    #####################
    # Android アップロード
    #####################
    upload_to_play_store(
      package_name: "com.joymath",
      json_key: File.expand_path("./joy-math-fastlane.json", __dir__),
      track: "production",
      aab: File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__),
      metadata_path: File.expand_path("./metadata/android", __dir__)
    )

    UI.success("✅ iOS & Android release complete")
  end
end

platform :android do
  desc "Android リリースを自動化"
  desc "オプション: skip_build:true (既存ビルドを使用)"
  lane :release_all do |options|
    release_note = options[:notes] || "バグ修正と改善を行いました"
    release_note_en = options[:notes_en] || "Bug fixes and improvements"
    skip_build = options[:skip_build] || false
    
    UI.header("🤖 Starting Android release")
    UI.message("📝 Release notes (ja): #{release_note.inspect}")
    UI.message("📝 Release notes (en): #{release_note_en.inspect}")

    # --- pubspec.yaml からバージョン取得 ---
    version_info = get_version_info
    version_number = version_info[:version]
    build_number = version_info[:build]

    UI.message("📦 Version: #{version_number} (#{build_number})")

    #####################
    # Flutter 共通ビルド
    #####################
    unless skip_build
      UI.header("🔨 Building Flutter app")
      sh("cd .. && flutter clean")
      sh("cd .. && flutter pub get")
      safe_pod_install
      sh("cd .. && flutter build appbundle --release --build-name #{version_number} --build-number #{build_number}")
    else
      UI.message("⏭️  Skipping build (using existing AAB)")
      aab_path = File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__)
      unless File.exist?(aab_path)
        UI.user_error!("❌ AAB file not found at #{aab_path}. Remove skip_build option or build first.")
      end
      UI.message("✅ Found existing AAB: #{aab_path}")
    end

    #####################
    # Android changelog 自動生成
    #####################
    generate_android_changelogs(build_number, release_note, release_note_en)

    #####################
    # Android アップロード
    #####################
    UI.header("📤 Uploading to Google Play")
    upload_to_play_store(
      package_name: "com.joymath",
      json_key: File.expand_path("./joy-math-fastlane.json", __dir__),
      track: "production",
      # ユーザーが Play Console 上で「審査へ送信」操作をする前提なので、ここでは review 送信しない
      changes_not_sent_for_review: true,
      aab: File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__),
      metadata_path: File.expand_path("./metadata/android", __dir__)
    )

    UI.success("✅ Android release complete")
  end
end
