# ローカルリリース用（.env にコピーして値を入れる。コミットしない）
#
# Android リリース (android_release.sh)
REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxx

# iOS ローカルビルド / Codemagic revenuecat_credentials
REVENUECAT_IOS_API_KEY=appl_xxxxxxxx

# App Store Connect API（setup_ios_ai_pass_release.sh）
# Codemagic の APP_STORE_CONNECT_PRIVATE_KEY と同じ .p8 を使える
ASC_KEY_ID=ATBD5UGJTG
ASC_ISSUER_ID=c64fb6be-f1d2-4e04-80b5-2841def3da52
ASC_P8_PATH=$HOME/.appstoreconnect/private_keys/AuthKey_ATBD5UGJTG.p8
# または .p8 全文を直接貼る（ASC_PRIVATE_KEY=...）
